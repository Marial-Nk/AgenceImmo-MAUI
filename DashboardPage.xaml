<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BaseMauiApp.DashboardPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F2F2F2">

    <Grid ColumnDefinitions="280,*" Padding="16" ColumnSpacing="16">

        <!-- ========== SIDEBAR ========== -->
        <Border Grid.Column="0"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 24"
                Stroke="Transparent">
            <Border.Shadow>
                <Shadow Brush="#CCCCCC" Offset="2,2" Radius="12" Opacity="0.15"/>
            </Border.Shadow>

            <ScrollView>
                <VerticalStackLayout Padding="12,16" Spacing="2">

                    <!-- === TABLEAU DE BORD (actif) === -->
                    <Grid ColumnDefinitions="4,*" Margin="0,4,0,4">
                        <BoxView Grid.Column="0" Color="#4AD395" CornerRadius="2"/>
                        <Border Grid.Column="1"
                                BackgroundColor="#E8F8F2"
                                StrokeShape="RoundRectangle 10"
                                Stroke="Transparent"
                                Padding="12,10">
                            <Label Text="🏠  Tableau de bord"
                                   FontAttributes="Bold"
                                   FontSize="14"
                                   TextColor="#1E1E2D"/>
                        </Border>
                    </Grid>

                    <!-- === BIENS === -->
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 10"
                            Stroke="Transparent" Padding="12,10" Margin="4,2">
                        <Label Text="🏢  Biens" FontAttributes="Bold" FontSize="14" TextColor="#333"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="📋  Liste des biens" FontSize="13" TextColor="#888">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnListeBiensTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="➕  Nouveau bien" FontSize="13" TextColor="#888">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNouveauBienTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="🕐  Historique des statuts" FontSize="13" TextColor="#888"/>
                    </Border>

                    <!-- === PERSONNES === -->
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 10"
                            Stroke="Transparent" Padding="12,10" Margin="4,2">
                        <Label Text="👥  Personnes" FontAttributes="Bold" FontSize="14" TextColor="#333"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="📋  Liste des personnes" FontSize="13" TextColor="#888"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="➕  Nouvelle personne" FontSize="13" TextColor="#888"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="🔗  Associés bien-personne" FontSize="13" TextColor="#888"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="🕐  Historique des interactions" FontSize="13" TextColor="#888"/>
                    </Border>

                    <!-- === ÉVÉNEMENTS === -->
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 10"
                            Stroke="Transparent" Padding="12,10" Margin="4,2">
                        <Label Text="📅  Événements" FontAttributes="Bold" FontSize="14" TextColor="#333"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="📋  Liste des événements" FontSize="13" TextColor="#888"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="➕  Nouvel événement" FontSize="13" TextColor="#888"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="🕐  Historique des interactions" FontSize="13" TextColor="#888"/>
                    </Border>

                    <!-- === DOCUMENTS === -->
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 10"
                            Stroke="Transparent" Padding="12,10" Margin="4,2">
                        <Label Text="📁  Documents" FontAttributes="Bold" FontSize="14" TextColor="#333"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="📋  Tous les documents" FontSize="13" TextColor="#888"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="➕  Nouveau document" FontSize="13" TextColor="#888"/>
                    </Border>

                    <!-- === UTILISATEURS === -->
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 10"
                            Stroke="Transparent" Padding="12,10" Margin="4,2">
                        <Label Text="👤  Utilisateurs" FontAttributes="Bold" FontSize="14" TextColor="#333"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="🔐  Déconnexion" FontSize="13" TextColor="#FF6B6B"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="👥  Gestion des utilisateurs" FontSize="13" TextColor="#888"/>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <!-- ========== CONTENU PRINCIPAL ========== -->
        <Border Grid.Column="1"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 20"
                Stroke="#644CFF"
                StrokeThickness="1">

            <ScrollView>
                <VerticalStackLayout Padding="24,20" Spacing="20">

                    <!-- Titre -->
                    <Label Text="Tableau de bord"
                           FontSize="24" FontAttributes="Bold" TextColor="#1E1E2D"/>

                    <!-- Cartes de statistiques -->
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">

                        <Border Grid.Column="0" BackgroundColor="White"
                                StrokeShape="RoundRectangle 14" Stroke="#EEEEEE" StrokeThickness="1" Padding="16">
                            <Border.Shadow>
                                <Shadow Brush="#CCCCCC" Offset="1,1" Radius="8" Opacity="0.1"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8">
                                <Border BackgroundColor="#EDE9FF" StrokeShape="RoundRectangle 10"
                                        Stroke="Transparent" Padding="10"
                                        HorizontalOptions="Start" WidthRequest="42" HeightRequest="42">
                                    <Label Text="🏢" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{Binding TotalBiens}" FontSize="28" FontAttributes="Bold" TextColor="#1E1E2D"/>
                                <Label Text="Total Biens" TextColor="#AAA" FontSize="12"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1" BackgroundColor="White"
                                StrokeShape="RoundRectangle 14" Stroke="#EEEEEE" StrokeThickness="1" Padding="16">
                            <Border.Shadow>
                                <Shadow Brush="#CCCCCC" Offset="1,1" Radius="8" Opacity="0.1"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8">
                                <Border BackgroundColor="#E8F8F2" StrokeShape="RoundRectangle 10"
                                        Stroke="Transparent" Padding="10"
                                        HorizontalOptions="Start" WidthRequest="42" HeightRequest="42">
                                    <Label Text="✅" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{Binding BiensDisponibles}" FontSize="28" FontAttributes="Bold" TextColor="#4AD395"/>
                                <Label Text="Disponibles" TextColor="#AAA" FontSize="12"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="2" BackgroundColor="White"
                                StrokeShape="RoundRectangle 14" Stroke="#EEEEEE" StrokeThickness="1" Padding="16">
                            <Border.Shadow>
                                <Shadow Brush="#CCCCCC" Offset="1,1" Radius="8" Opacity="0.1"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8">
                                <Border BackgroundColor="#FFF3E0" StrokeShape="RoundRectangle 10"
                                        Stroke="Transparent" Padding="10"
                                        HorizontalOptions="Start" WidthRequest="42" HeightRequest="42">
                                    <Label Text="🤝" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{Binding BiensEnNegociation}" FontSize="28" FontAttributes="Bold" TextColor="#FFA726"/>
                                <Label Text="En Négociation" TextColor="#AAA" FontSize="12"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="3" BackgroundColor="White"
                                StrokeShape="RoundRectangle 14" Stroke="#EEEEEE" StrokeThickness="1" Padding="16">
                            <Border.Shadow>
                                <Shadow Brush="#CCCCCC" Offset="1,1" Radius="8" Opacity="0.1"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8">
                                <Border BackgroundColor="#E3F2FD" StrokeShape="RoundRectangle 10"
                                        Stroke="Transparent" Padding="10"
                                        HorizontalOptions="Start" WidthRequest="42" HeightRequest="42">
                                    <Label Text="🔑" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{Binding BiensVendus}" FontSize="28" FontAttributes="Bold" TextColor="#42A5F5"/>
                                <Label Text="Vendus / Loués" TextColor="#AAA" FontSize="12"/>
                            </VerticalStackLayout>
                        </Border>

                    </Grid>

                    <!-- Séparateur -->
                    <BoxView HeightRequest="1" Color="#F0F0F0"/>

                    <!-- Lien vers la liste -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Derniers événements"
                               FontSize="18" FontAttributes="Bold" TextColor="#1E1E2D"
                               VerticalOptions="Center"/>
                        <Border Grid.Column="1" BackgroundColor="#EDE9FF"
                                StrokeShape="RoundRectangle 20" Stroke="Transparent" Padding="14,8">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnListeBiensTapped"/>
                            </Border.GestureRecognizers>
                            <Label Text="Voir tous les biens →" TextColor="#644CFF" FontSize="13" FontAttributes="Bold"/>
                        </Border>
                    </Grid>

                    <!-- Événements récents -->
                    <CollectionView ItemsSource="{Binding EvenementsRecents}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="White" StrokeShape="RoundRectangle 12"
                                        Stroke="#EEEEEE" StrokeThickness="1" Padding="0" Margin="0,0,0,10">
                                    <Border.Shadow>
                                        <Shadow Brush="#CCCCCC" Offset="1,1" Radius="6" Opacity="0.08"/>
                                    </Border.Shadow>
                                    <Grid ColumnDefinitions="5,*" ColumnSpacing="0">
                                        <BoxView Grid.Column="0" Color="{Binding TypeColor}" CornerRadius="6,0,0,6"/>
                                        <Grid Grid.Column="1" ColumnDefinitions="*,Auto"
                                              RowDefinitions="Auto,Auto" Padding="16,12">
                                            <Label Grid.Row="0" Grid.Column="0"
                                                   Text="{Binding Type}"
                                                   FontAttributes="Bold" FontSize="14" TextColor="#1E1E2D"/>
                                            <Border Grid.Row="0" Grid.Column="1"
                                                    BackgroundColor="#F0EDFF" StrokeShape="RoundRectangle 20"
                                                    Stroke="Transparent" Padding="10,4">
                                                <Label Text="{Binding Date}" TextColor="#644CFF" FontSize="12" FontAttributes="Bold"/>
                                            </Border>
                                            <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                   FontSize="13" TextColor="#666" Margin="0,4,0,0">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding Bien}" TextColor="#9999BB"/>
                                                        <Span Text=" — "/>
                                                        <Span Text="{Binding Description}"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.EmptyView>
                            <Label Text="Aucun événement récent." HorizontalOptions="Center"
                                   TextColor="#AAAAAA" Margin="0,20"/>
                        </CollectionView.EmptyView>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>
        </Border>

    </Grid>
</ContentPage>
