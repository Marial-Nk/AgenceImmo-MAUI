<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BaseMauiApp.DetailsBienPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F2F2F2">

    <Grid ColumnDefinitions="280,*" Padding="16" ColumnSpacing="16">

        <!-- ========== SIDEBAR ========== -->
        <Border Grid.Column="0"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 24"
                Stroke="Transparent">
            <Border.Shadow>
                <Shadow Brush="#CCCCCC" Offset="2,2" Radius="12" Opacity="0.15"/>
            </Border.Shadow>

            <ScrollView>
                <VerticalStackLayout Padding="12,16" Spacing="2">

                    <!-- Tableau de bord -->
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 10"
                            Stroke="Transparent" Padding="12,10" Margin="4,2">
                        <Label Text="🏠  Tableau de bord" FontAttributes="Bold" FontSize="14" TextColor="#333">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRetourDashboardTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <!-- BIENS (actif) -->
                    <Grid ColumnDefinitions="4,*" Margin="0,4,0,4">
                        <BoxView Grid.Column="0" Color="#4AD395" CornerRadius="2"/>
                        <Border Grid.Column="1"
                                BackgroundColor="#E8F8F2"
                                StrokeShape="RoundRectangle 10"
                                Stroke="Transparent"
                                Padding="12,10">
                            <Label Text="🏢  Biens"
                                   FontAttributes="Bold" FontSize="14" TextColor="#1E1E2D"/>
                        </Border>
                    </Grid>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="📋  Liste des biens" FontSize="13" TextColor="#888">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnListeBiensTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="➕  Nouveau bien" FontSize="13" TextColor="#888"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="🕐  Historique des statuts" FontSize="13" TextColor="#888"/>
                    </Border>

                    <!-- Personnes -->
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 10"
                            Stroke="Transparent" Padding="12,10" Margin="4,2">
                        <Label Text="👥  Personnes" FontAttributes="Bold" FontSize="14" TextColor="#333"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="📋  Liste des personnes" FontSize="13" TextColor="#888"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="➕  Nouvelle personne" FontSize="13" TextColor="#888"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="🔗  Associés bien-personne" FontSize="13" TextColor="#888"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="🕐  Historique des interactions" FontSize="13" TextColor="#888"/>
                    </Border>

                    <!-- Événements -->
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 10"
                            Stroke="Transparent" Padding="12,10" Margin="4,2">
                        <Label Text="📅  Événements" FontAttributes="Bold" FontSize="14" TextColor="#333"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="📋  Liste des événements" FontSize="13" TextColor="#888"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="➕  Nouvel événement" FontSize="13" TextColor="#888"/>
                    </Border>

                    <!-- Documents -->
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 10"
                            Stroke="Transparent" Padding="12,10" Margin="4,2">
                        <Label Text="📁  Documents" FontAttributes="Bold" FontSize="14" TextColor="#333"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="📋  Tous les documents" FontSize="13" TextColor="#888"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="➕  Nouveau document" FontSize="13" TextColor="#888"/>
                    </Border>

                    <!-- Utilisateurs -->
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 10"
                            Stroke="Transparent" Padding="12,10" Margin="4,2">
                        <Label Text="👤  Utilisateurs" FontAttributes="Bold" FontSize="14" TextColor="#333"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="🔐  Déconnexion" FontSize="13" TextColor="#FF6B6B"/>
                    </Border>
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="10,7" Margin="28,1,4,1">
                        <Label Text="👥  Gestion des utilisateurs" FontSize="13" TextColor="#888"/>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <!-- ========== CONTENU ========== -->
        <Border Grid.Column="1"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 20"
                Stroke="#644CFF"
                StrokeThickness="1">

            <Grid RowDefinitions="Auto,*">

                <!-- En-tête violet -->
                <Grid Grid.Row="0" BackgroundColor="#644CFF" Padding="24,18"
                      ColumnDefinitions="Auto,*">

                    <!-- Bouton retour -->
                    <Border Grid.Column="0"
                            BackgroundColor="#7B65FF"
                            StrokeShape="RoundRectangle 20"
                            Stroke="Transparent"
                            Padding="14,8"
                            Margin="0,0,20,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRetourDashboardTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="← Retour à la liste des biens"
                               TextColor="White" FontSize="13"/>
                    </Border>

                    <!-- Titre -->
                    <Label Grid.Column="1"
                           Text="Détails du bien"
                           TextColor="White"
                           FontSize="22"
                           FontAttributes="Bold"
                           VerticalOptions="Center"/>
                </Grid>

                <!-- Corps de la page -->
                <ScrollView Grid.Row="1" Padding="24">
                    <VerticalStackLayout Spacing="20">

                        <!-- Panneau principal : identification + informations -->
                        <Grid ColumnDefinitions="220,*" ColumnSpacing="20">

                            <!-- Identification (placeholder image) -->
                            <Border Grid.Column="0"
                                    StrokeDashArray="4,4"
                                    Stroke="#644CFF"
                                    StrokeThickness="1.5"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="#F8F6FF"
                                    Padding="16"
                                    HeightRequest="220">
                                <VerticalStackLayout VerticalOptions="Center"
                                                     HorizontalOptions="Center"
                                                     Spacing="10">
                                    <Label Text="🏠"
                                           FontSize="52"
                                           HorizontalOptions="Center"
                                           Opacity="0.5"/>
                                    <Label Text="{Binding TypeBien}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#644CFF"
                                           HorizontalOptions="Center"/>
                                    <Label Text="Bien immobilier"
                                           FontSize="12"
                                           TextColor="#AAAAAA"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>

                            <!-- Informations -->
                            <Border Grid.Column="1"
                                    BackgroundColor="White"
                                    StrokeShape="RoundRectangle 14"
                                    Stroke="#EEEEEE"
                                    StrokeThickness="1"
                                    Padding="24">
                                <Border.Shadow>
                                    <Shadow Brush="#CCCCCC" Offset="1,2" Radius="8" Opacity="0.1"/>
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="16">

                                    <Label Text="Information"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="#1E1E2D"/>

                                    <BoxView HeightRequest="1" Color="#F0F0F0"/>

                                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto"
                                          ColumnSpacing="20" RowSpacing="14">

                                        <!-- Identifiant -->
                                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                                            <Label Text="Identifiant" FontSize="12" TextColor="#AAAAAA"/>
                                            <Border BackgroundColor="#F8F8F8"
                                                    StrokeShape="RoundRectangle 8"
                                                    Stroke="#EEEEEE" Padding="12,10">
                                                <Label Text="{Binding IdBien}"
                                                       FontSize="14" TextColor="#1E1E2D"/>
                                            </Border>
                                        </VerticalStackLayout>

                                        <!-- Type de bien -->
                                        <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="4">
                                            <Label Text="Type de bien" FontSize="12" TextColor="#AAAAAA"/>
                                            <Border BackgroundColor="#F8F8F8"
                                                    StrokeShape="RoundRectangle 8"
                                                    Stroke="#EEEEEE" Padding="12,10">
                                                <Label Text="{Binding TypeBien}"
                                                       FontSize="14" TextColor="#1E1E2D"/>
                                            </Border>
                                        </VerticalStackLayout>

                                        <!-- Statut -->
                                        <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="4">
                                            <Label Text="Statut" FontSize="12" TextColor="#AAAAAA"/>
                                            <Border BackgroundColor="#F8F8F8"
                                                    StrokeShape="RoundRectangle 8"
                                                    Stroke="#EEEEEE" Padding="12,10">
                                                <Label Text="{Binding Statut}"
                                                       FontSize="14" TextColor="#1E1E2D"/>
                                            </Border>
                                        </VerticalStackLayout>

                                        <!-- Description -->
                                        <VerticalStackLayout Grid.Row="1" Grid.Column="1"
                                                             Grid.RowSpan="2" Spacing="4">
                                            <Label Text="Description" FontSize="12" TextColor="#AAAAAA"/>
                                            <Border BackgroundColor="#F8F8F8"
                                                    StrokeShape="RoundRectangle 8"
                                                    Stroke="#EEEEEE" Padding="12,10">
                                                <Label Text="{Binding Description}"
                                                       FontSize="14" TextColor="#555"
                                                       LineBreakMode="WordWrap"/>
                                            </Border>
                                        </VerticalStackLayout>

                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <!-- Section Événements -->
                        <VerticalStackLayout Spacing="14">

                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="Événements"
                                       FontSize="18" FontAttributes="Bold" TextColor="#1E1E2D"
                                       VerticalOptions="Center"/>
                                <Border Grid.Column="1"
                                        BackgroundColor="#EDE9FF"
                                        StrokeShape="RoundRectangle 20"
                                        Stroke="Transparent"
                                        Padding="14,6">
                                    <Label Text="{Binding Evenements.Count, StringFormat='{0} événement(s)'}"
                                           TextColor="#644CFF" FontSize="12" FontAttributes="Bold"/>
                                </Border>
                            </Grid>

                            <CollectionView ItemsSource="{Binding Evenements}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="White"
                                                StrokeShape="RoundRectangle 12"
                                                Stroke="#EEEEEE"
                                                StrokeThickness="1"
                                                Padding="0"
                                                Margin="0,0,0,10">
                                            <Border.Shadow>
                                                <Shadow Brush="#CCCCCC" Offset="1,1" Radius="6" Opacity="0.08"/>
                                            </Border.Shadow>
                                            <Grid ColumnDefinitions="5,*" ColumnSpacing="0">
                                                <BoxView Grid.Column="0" Color="#644CFF" CornerRadius="6,0,0,6"/>
                                                <Grid Grid.Column="1"
                                                      ColumnDefinitions="*,Auto"
                                                      Padding="16,14"
                                                      RowDefinitions="Auto,Auto">
                                                    <Label Grid.Row="0" Grid.Column="0"
                                                           Text="{Binding Type}"
                                                           FontAttributes="Bold"
                                                           FontSize="14"
                                                           TextColor="#1E1E2D"/>
                                                    <Border Grid.Row="0" Grid.Column="1"
                                                            BackgroundColor="#F0EDFF"
                                                            StrokeShape="RoundRectangle 20"
                                                            Stroke="Transparent"
                                                            Padding="10,4">
                                                        <Label Text="{Binding Date}"
                                                               TextColor="#644CFF"
                                                               FontSize="12"
                                                               FontAttributes="Bold"/>
                                                    </Border>
                                                    <Label Grid.Row="1" Grid.Column="0"
                                                           Grid.ColumnSpan="2"
                                                           Text="{Binding Description}"
                                                           FontSize="13"
                                                           TextColor="#666"
                                                           Margin="0,6,0,0"
                                                           LineBreakMode="WordWrap"/>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                                <CollectionView.EmptyView>
                                    <Border BackgroundColor="#F8F8F8"
                                            StrokeShape="RoundRectangle 12"
                                            Stroke="#EEEEEE"
                                            Padding="24">
                                        <Label Text="Aucun événement enregistré pour ce bien."
                                               HorizontalOptions="Center"
                                               TextColor="#AAAAAA"
                                               FontSize="14"/>
                                    </Border>
                                </CollectionView.EmptyView>
                            </CollectionView>

                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Border>

    </Grid>
</ContentPage>
