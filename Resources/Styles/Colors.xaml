<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Couleurs principales -->
    <Color x:Key="PrimaryViolet">#644CFF</Color>
    <Color x:Key="PrimaryGreen">#4AD395</Color>
    <Color x:Key="PrimaryGray">#E0E0E0</Color>

    <!-- Couleurs neutres -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>

    <!-- Couleurs UI -->
    <Color x:Key="BorderColor">#644CFF</Color>
    <Color x:Key="ShadowColor">#644CFF</Color>
    <Color x:Key="ErrorColor">#FF6B6B</Color>

</ResourceDictionary>
