<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Style Texte Titre -->
    <Style TargetType="Label" x:Key="TitleLabel">
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="TextColor" Value="{StaticResource Black}"/>
    </Style>

    <!-- Style Label simple -->
    <Style TargetType="Label" x:Key="FieldLabel">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource Black}"/>
    </Style>

    <!-- Style des champs (Entry / Picker / Editor) -->
    <Style TargetType="Border" x:Key="FieldBorder">
        <Setter Property="Stroke" Value="{StaticResource BorderColor}"/>
        <Setter Property="StrokeThickness" Value="0.4"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 10"/>
        <Setter Property="BackgroundColor" Value="White"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <!-- Style Bouton Primaire (Enregistrer) -->
    <Style TargetType="Button" x:Key="PrimaryButton">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryGreen}"/>
        <Setter Property="TextColor" Value="Black"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <!-- Style Bouton Secondaire (Annuler) -->
    <Style TargetType="Button" x:Key="SecondaryButton">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryGray}"/>
        <Setter Property="TextColor" Value="Black"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <!-- Style du Switch -->
    <Style TargetType="Switch" x:Key="PublishSwitch">
        <Setter Property="OnColor" Value="{StaticResource PrimaryViolet}"/>
        <Setter Property="ThumbColor" Value="Black"/>
    </Style>

</ResourceDictionary>
